{
  "name": "personal-hub",
  "version": "1.0.0",
  "description": "个人效率中心 - 跨平台应用",
  "main": "electron/main.js",
  "scripts": {
    "start": "npx http-server . -p 8080 -c-1 --cors",
    "electron": "electron .",
    "build:electron": "electron-builder",
    "build:android": "npx cap copy android && npx cap open android",
    "build:ios": "npx cap copy ios && npx cap open ios"
  },
  "keywords": ["productivity", "todo", "pomodoro", "habit-tracker"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "http-server": "^14.1.1"
  },
  "dependencies": {
    "@capacitor/android": "^5.6.0",
    "@capacitor/core": "^5.6.0",
    "@capacitor/ios": "^5.6.0"
  },
  "build": {
    "appId": "com.personalhub.app",
    "productName": "个人效率中心",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "www/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "www/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "www/icon.png"
    }
  }
}
